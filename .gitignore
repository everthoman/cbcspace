# Python
__pycache__/
*.py[cod]

# Runtime session uploads (per-user, ephemeral)
backend/sessions/

# Server log
server.log

# Local agent/editor settings
.claude/

# Default library data: keep the synthetic demo sets (regenerated by
# make_defaults.py), but never track/push real libraries published to the
# server (they live on disk only).
backend/data/defaults/*.parquet
!backend/data/defaults/aromatic-leads.parquet
!backend/data/defaults/aliphatic-scaffolds.parquet
!backend/data/defaults/polar-fragments.parquet
